{
  "entities": {
    "DailyEntry": {
      "title": "Daily Entry",
      "description": "A financial entry for a specific day",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "storeName": { "type": "string" },
        "grossAmount": { "type": "number" },
        "fuel": { "type": "number" },
        "food": { "type": "number" },
        "maintenance": { "type": "number" },
        "others": { "type": "number" },
        "netAmount": { "type": "number" },
        "kmDriven": { "type": "number" },
        "fuelPrice": { "type": "number" },
        "liters": { "type": "number" },
        "kmAtMaintenance": { "type": "number" },
        "kmType": { "type": "string", "enum": ["work", "personal"] },
        "paymentMethod": { "type": "string", "enum": ["money", "pix", "debito", "caderno"] },
        "isPaid": { "type": "boolean" },
        "category": { "type": "string", "enum": ["income", "fuel", "food", "maintenance", "others"] }
      },
      "required": ["id", "date", "time", "storeName", "grossAmount", "netAmount"]
    },
    "AppConfig": {
      "title": "App Configuration",
      "description": "User specific application settings",
      "type": "object",
      "properties": {
        "percFuel": { "type": "number" },
        "percFood": { "type": "number" },
        "percMaintenance": { "type": "number" },
        "percOthers": { "type": "number" },
        "dailyGoal": { "type": "number" },
        "lastFuelPrice": { "type": "number" },
        "lastTotalKm": { "type": "number" },
        "themeMode": { "type": "string", "enum": ["light", "dark", "auto"] },
        "notificationsEnabled": { "type": "boolean" }
      }
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "nickname": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPro": { "type": "boolean" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "canceled", "past_due", "none"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserDocument": {
      "title": "User Document",
      "description": "Main user document containing all data",
      "type": "object",
      "properties": {
        "entries": { "type": "array", "items": { "$ref": "DailyEntry" } },
        "timeEntries": { "type": "array", "items": { "type": "object" } },
        "config": { "$ref": "AppConfig" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "TimeEntriesDocument": {
      "title": "Time Entries Document",
      "description": "Document containing all time entries (points)",
      "type": "object",
      "properties": {
        "timeEntries": { "type": "array", "items": { "type": "object" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["timeEntries"]
    },
    "RotaBankEntry": {
      "title": "RotaBank Entry",
      "description": "Entry synchronized to RotaBank",
      "type": "object",
      "properties": {
        "netAmount": { "type": "number" },
        "valor_liquido": { "type": "number" },
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      },
      "required": ["netAmount", "uid", "date", "description"]
    },
    "MonthlyBalance": {
      "title": "Monthly Balance",
      "description": "The total net amount for the current month",
      "type": "object",
      "properties": {
        "totalNetAmount": { "type": "number" },
        "valor_liquido": { "type": "number" },
        "uid": { "type": "string" },
        "month": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["totalNetAmount", "uid", "month"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserDocument",
      "description": "User document containing all application data"
    },
    "/entries/{entryId}": {
      "schema": "RotaBankEntry",
      "description": "Global entries collection for RotaBank synchronization"
    },
    "/balances/{userId}": {
      "schema": "MonthlyBalance",
      "description": "Monthly balance for RotaBank synchronization"
    },
    "/time_entries/{userId}": {
      "schema": "TimeEntriesDocument",
      "description": "Separate collection for user time entries (points)"
    }
  }
}
